DATABASE_URL="postgresql://skillshub:skillshub_dev@localhost:5433/skillshub"

# Admin auth (independent simple auth — NOT NextAuth)
ADMIN_PASSWORD="set-a-strong-password"
AUTH_SECRET="generate-with: openssl rand -base64 32"

# Object storage (RustFS / S3)
# 本地默认值,与 docker-compose.yml 的 RUSTFS_* 一致;生产请改。
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="skillshub"
S3_SECRET_KEY="skillshub_dev"
S3_BUCKET="skills"
APP_URL="http://localhost:3000"
