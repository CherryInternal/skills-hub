# Copy to `.env` next to docker-compose.prod.yml and fill in real secrets.
# docker compose reads this file automatically.

# === Database (内部网络,不对外暴露) ===
POSTGRES_USER=skillshub
POSTGRES_PASSWORD=__CHANGE_ME_strong_password__
POSTGRES_DB=skillshub

# === Object storage (RustFS) ===
S3_ACCESS_KEY=skillshub
S3_SECRET_KEY=__CHANGE_ME_strong_secret__
S3_BUCKET=skills
# IMPORTANT: downloads use presigned URLs that the *browser* hits directly, so
# this must be the PUBLIC host your nginx maps to rustfs:9000 — NOT the internal
# http://rustfs:9000. e.g. https://storage.example.com
S3_ENDPOINT=https://storage.example.com

# === App ===
APP_URL=https://skills.example.com
# openssl rand -base64 32
AUTH_SECRET=__CHANGE_ME_random_32_bytes__
ADMIN_PASSWORD=__CHANGE_ME_admin_password__
# How many trusted reverse-proxy hops are in front of the app (nginx = 1).
# Used to read the real client IP for rate limiting. Direct exposure → 0.
TRUSTED_PROXY_HOPS=1
